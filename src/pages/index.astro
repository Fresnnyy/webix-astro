---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
    <Header />
    <main>

        <!-- HERO -->
        <section class="hero-section relative flex items-center justify-center px-[8%] text-center">
            <!-- Badges flotantes -->
            <span class="hero-badge hero-float--1" aria-hidden="true" style="background:#AF4D98;color:#fff;top:14%;left:3%;">Diseño Web</span>
            <span class="hero-badge hero-float--2" aria-hidden="true" style="background:#FFE900;color:#111;top:54%;left:2%;">SEO Local</span>
            <span class="hero-badge hero-float--3 badge-hide-mobile" aria-hidden="true" style="background:#119DA4;color:#fff;bottom:20%;left:3%;">Landing Pages</span>
            <span class="hero-badge hero-float--4" aria-hidden="true" style="background:#FF7B00;color:#fff;top:14%;right:2%;">Google Ads</span>
            <span class="hero-badge hero-float--5" aria-hidden="true" style="background:#AF4D98;color:#fff;top:52%;right:2%;">E-commerce</span>
            <span class="hero-badge hero-float--6 badge-hide-mobile" aria-hidden="true" style="background:#1a1a1a;color:#FFE900;bottom:18%;right:3%;">Identidad Visual</span>
            <span class="hero-badge hero-float--7 badge-hide-mobile" aria-hidden="true" style="background:#119DA4;color:#fff;top:18%;left:20%;">Redes Sociales</span>
            <span class="hero-badge hero-float--8 badge-hide-mobile" aria-hidden="true" style="background:#FF7B00;color:#fff;top:16%;right:18%;">WhatsApp Business</span>
            <div class="relative z-10 text-center">
                <h1 class="font-title text-[2.6rem] md:text-[3.8rem] leading-[1.05] tracking-[-2px] mb-12">
                    <div class="hero-line">Diseño de páginas <span class="highlight-orange">web</span></div>
                    <div class="hero-line">para negocios que quieren</div>
                    <div class="hero-line"><span class="highlight-yellow">atraer</span> más clientes.</div>
                </h1>
                <a href="https://wa.me/525650776884" target="_blank" rel="noopener noreferrer"
                   class="btn-hero inline-flex items-center bg-purple text-white no-underline px-10 py-4 rounded-full text-xl font-semibold">
                    Empecemos hoy &nbsp;&#9658;
                </a>
            </div>
        </section>

        <!-- MARQUEE -->
        <div class="marquee-wrapper">
            <div class="marquee-track">
                <div class="marquee-content">
                    <span>+150 Webs Entregadas</span>
                    <span>98% Clientes Satisfechos</span>
                    <span>+10 años de Experiencia Digital</span>
                    <span>Soporte 24/7</span>
                </div>
                <div class="marquee-content" aria-hidden="true">
                    <span>+150 Webs Entregadas</span>
                    <span>98% Clientes Satisfechos</span>
                    <span>+10 años de Experiencia Digital</span>
                    <span>Soporte 24/7</span>
                </div>
            </div>
        </div>

        <!-- DESAFÍOS -->
        <section class="bg-cream flex flex-col items-center" id="desafios">
            <div class="section-title text-center pt-24 pb-12 px-[8%]">
                <h2 class="font-title text-[2.5rem] md:text-[3.5rem] font-normal">
                    <span class="highlight-orange-title">Desafíos</span> Digitales
                </h2>
                <p class="text-gray-500 text-lg mt-4 max-w-[550px] mx-auto">Si te identificas con alguno, es momento de actuar.</p>
            </div>
            <div class="desafios-stack w-full px-[8%] pb-24" id="desafios-stack">
                <div class="desafio-card desafio-sticky rounded-3xl p-10 md:p-14 max-w-[800px] mx-auto shadow-lg flex flex-col md:flex-row items-center gap-8 md:gap-12" style="background-color:#AF4D98; --card-index:0;">
                    <div class="flex-shrink-0 flex flex-col items-center">
                        <span class="font-title text-[5rem] md:text-[6rem] leading-none text-white" style="opacity:0.3">01</span>
                        <svg class="mt-2" width="48" height="48" viewBox="0 0 24 24" fill="none"><path d="M21 21l-4.35-4.35M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
                    </div>
                    <div class="text-center md:text-left">
                        <h3 class="font-title text-2xl md:text-3xl text-white mb-2">Invisible en línea</h3>
                        <p class="desafio-stat font-body text-[3.5rem] md:text-[4.5rem] font-black text-white leading-none mb-3">75%</p>
                        <p class="text-white text-base md:text-lg leading-relaxed" style="opacity:0.85">De los usuarios no pasa de la primera página de Google. Si no te encuentran, pierdes clientes cada día.</p>
                    </div>
                </div>
                <div class="desafio-card desafio-sticky rounded-3xl p-10 md:p-14 max-w-[800px] mx-auto shadow-lg flex flex-col md:flex-row items-center gap-8 md:gap-12" style="background-color:#FF7B00; --card-index:1;">
                    <div class="flex-shrink-0 flex flex-col items-center">
                        <span class="font-title text-[5rem] md:text-[6rem] leading-none text-white" style="opacity:0.3">02</span>
                        <svg class="mt-2" width="48" height="48" viewBox="0 0 24 24" fill="none"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" stroke="white" stroke-width="2"/><path d="M8 15s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
                    </div>
                    <div class="text-center md:text-left">
                        <h3 class="font-title text-2xl md:text-3xl text-white mb-2">Sin confianza visual</h3>
                        <p class="desafio-stat font-body text-[3.5rem] md:text-[4.5rem] font-black text-white leading-none mb-3">75%</p>
                        <p class="text-white text-base md:text-lg leading-relaxed" style="opacity:0.85">De los usuarios juzgan tu credibilidad por el diseño. Una imagen anticuada aleja oportunidades de negocio.</p>
                    </div>
                </div>
                <div class="desafio-card desafio-sticky rounded-3xl p-10 md:p-14 max-w-[800px] mx-auto shadow-lg flex flex-col md:flex-row items-center gap-8 md:gap-12" style="background-color:#119DA4; --card-index:2;">
                    <div class="flex-shrink-0 flex flex-col items-center">
                        <span class="font-title text-[5rem] md:text-[6rem] leading-none text-white" style="opacity:0.3">03</span>
                        <svg class="mt-2" width="48" height="48" viewBox="0 0 24 24" fill="none"><rect x="5" y="2" width="14" height="20" rx="3" stroke="white" stroke-width="2"/><path d="M12 18h.01" stroke="white" stroke-width="2" stroke-linecap="round"/></svg>
                    </div>
                    <div class="text-center md:text-left">
                        <h3 class="font-title text-2xl md:text-3xl text-white mb-2">Pierdes clientes móviles</h3>
                        <p class="desafio-stat font-body text-[3.5rem] md:text-[4.5rem] font-black text-white leading-none mb-3">79%</p>
                        <p class="text-white text-base md:text-lg leading-relaxed" style="opacity:0.85">De las compras online se hacen desde el móvil. Una web no responsiva te hace perder ventas constantemente.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- QUÉ HACEMOS -->
        <section class="qh-section px-[8%] py-28" id="que-hacemos">
            <div class="max-w-[1160px] mx-auto">
                <div class="text-center mb-20">
                    <h2 class="font-title text-[2.5rem] md:text-[3.5rem] font-normal leading-[1.05]">
                        Todo lo necesario para lanzar<br>
                        una <span class="highlight-orange-title">presencia digital</span> sólida
                    </h2>
                </div>

                <div class="qh-grid">

                    <!-- Card 1 -->
                    <div class="qh-card" style="--qh-color:#AF4D98; --qh-accent:#FFE900;">
                        <span class="qh-bg-num font-title" aria-hidden="true">01</span>
                        <div class="qh-flood" aria-hidden="true"></div>
                        <div class="qh-body">
                            <span class="qh-tag">Diseño</span>
                            <h3 class="font-title qh-title">Diseño web<br>moderno.</h3>
                            <p class="qh-desc">Creamos páginas visualmente cuidadas, adaptadas a celular y pensadas para comunicar con claridad.</p>
                            <span class="qh-arrow" aria-hidden="true">→</span>
                        </div>
                    </div>

                    <!-- Card 2 -->
                    <div class="qh-card" style="--qh-color:#119DA4; --qh-accent:#FFE900;">
                        <span class="qh-bg-num font-title" aria-hidden="true">02</span>
                        <div class="qh-flood" aria-hidden="true"></div>
                        <div class="qh-body">
                            <span class="qh-tag">SEO</span>
                            <h3 class="font-title qh-title">Posicionamiento<br>en Google.</h3>
                            <p class="qh-desc">Títulos, metadatos, velocidad y datos estructurados para que Google y los motores de IA te encuentren.</p>
                            <span class="qh-arrow" aria-hidden="true">→</span>
                        </div>
                    </div>

                    <!-- Card 3 -->
                    <div class="qh-card" style="--qh-color:#FF7B00; --qh-accent:#FFE900;">
                        <span class="qh-bg-num font-title" aria-hidden="true">03</span>
                        <div class="qh-flood" aria-hidden="true"></div>
                        <div class="qh-body">
                            <span class="qh-tag">Infraestructura</span>
                            <h3 class="font-title qh-title">Hosting, dominio<br>y mantenimiento.</h3>
                            <p class="qh-desc">Nos encargamos de la parte técnica para que tu página esté siempre activa y segura.</p>
                            <span class="qh-arrow" aria-hidden="true">→</span>
                        </div>
                    </div>

                    <!-- Card 4 -->
                    <div class="qh-card" style="--qh-color:#111111; --qh-accent:#FFE900;">
                        <span class="qh-bg-num font-title" aria-hidden="true">04</span>
                        <div class="qh-flood" aria-hidden="true"></div>
                        <div class="qh-body">
                            <span class="qh-tag">Contacto</span>
                            <h3 class="font-title qh-title">Formularios<br>y conversión.</h3>
                            <p class="qh-desc">WhatsApp, formularios, mapas y botones de contacto integrados según el perfil de tu cliente.</p>
                            <span class="qh-arrow" aria-hidden="true">→</span>
                        </div>
                    </div>

                </div>
            </div>
        </section>

        <!-- PROCESO -->
        <section class="bg-white" id="proceso">
            <div class="text-center pt-24 pb-2 px-[8%]">
                <h2 class="font-title text-[2.5rem] md:text-[3.5rem] font-normal leading-[1.05]">
                    Sin sorpresas. Sin esperas.<br>
                    <span class="highlight-yellow">Sin estrés.</span>
                </h2>
                <p class="text-gray-500 text-lg mt-4 max-w-[500px] mx-auto">Un proceso claro desde la primera conversación hasta el lanzamiento.</p>
            </div>
            <div class="proceso-section" id="proceso-steps">
                <div class="proceso-grid">

                    <div class="proceso-pasos">

                        <div class="paso-item" data-paso="0">
                            <div class="paso-marker">
                                <span class="paso-num">Día 1</span>
                            </div>
                            <div class="paso-content">
                                <div class="paso-header">
                                    <h3 class="font-title paso-titulo">Hablamos</h3>
                                    <span class="paso-tiempo">30–60 min</span>
                                </div>
                                <p class="paso-desc">Nos cuentas tu proyecto y definimos objetivos. Sin formularios, sin vueltas.</p>
                            </div>
                        </div>

                        <div class="paso-item" data-paso="1">
                            <div class="paso-marker">
                                <span class="paso-num">Día 2</span>
                            </div>
                            <div class="paso-content">
                                <div class="paso-header">
                                    <h3 class="font-title paso-titulo">Proponemos</h3>
                                    <span class="paso-tiempo">24 hrs después</span>
                                </div>
                                <p class="paso-desc">Recibes propuesta con mapa del sitio, presupuesto cerrado y tiempos. Nada de "depende".</p>
                            </div>
                        </div>

                        <div class="paso-item" data-paso="2">
                            <div class="paso-marker">
                                <span class="paso-num">Día 3</span>
                            </div>
                            <div class="paso-content">
                                <div class="paso-header">
                                    <h3 class="font-title paso-titulo">Diseñamos</h3>
                                    <span class="paso-tiempo">Primer diseño</span>
                                </div>
                                <p class="paso-desc">Creamos la identidad visual con tu paleta, tipografía y estilo. Te mandamos el diseño para feedback.</p>
                            </div>
                        </div>

                        <div class="paso-item" data-paso="3">
                            <div class="paso-marker">
                                <span class="paso-num">Día 4</span>
                            </div>
                            <div class="paso-content">
                                <div class="paso-header">
                                    <h3 class="font-title paso-titulo">Construimos</h3>
                                    <span class="paso-tiempo">Código limpio</span>
                                </div>
                                <p class="paso-desc">Pasamos el diseño a código optimizado, rápido y 100% responsive. SEO técnico incluido.</p>
                            </div>
                        </div>

                        <div class="paso-item" data-paso="4">
                            <div class="paso-marker">
                                <span class="paso-num">Día 5</span>
                            </div>
                            <div class="paso-content">
                                <div class="paso-header">
                                    <h3 class="font-title paso-titulo">Ajustamos</h3>
                                    <span class="paso-tiempo">Tus cambios</span>
                                </div>
                                <p class="paso-desc">Revisas el sitio, pides cambios y los corregimos. Sin costo extra.</p>
                            </div>
                        </div>

                        <div class="paso-item" data-paso="5">
                            <div class="paso-marker">
                                <span class="paso-num">Día 6</span>
                            </div>
                            <div class="paso-content">
                                <div class="paso-header">
                                    <h3 class="font-title paso-titulo">Checklist</h3>
                                    <span class="paso-tiempo">Pre-lanzamiento</span>
                                </div>
                                <p class="paso-desc">Revisamos velocidad, responsive, SSL, formularios y Analytics antes de publicar.</p>
                            </div>
                        </div>

                        <div class="paso-item" data-paso="6">
                            <div class="paso-marker">
                                <span class="paso-num">Día 7</span>
                            </div>
                            <div class="paso-content">
                                <div class="paso-header">
                                    <h3 class="font-title paso-titulo">Publicamos</h3>
                                    <span class="paso-tiempo">🚀 En vivo</span>
                                </div>
                                <p class="paso-desc">Tu sitio está publicado.</p>
                            </div>
                        </div>

                    </div>

                    <div class="proceso-mockup-wrap">
                        <div class="proceso-mockup" id="proceso-mockup">
                            <div class="mock-bar">
                                <div class="mock-dots">
                                    <span class="mock-dot" style="background:#ff5f57"></span>
                                    <span class="mock-dot" style="background:#ffbd2e"></span>
                                    <span class="mock-dot" style="background:#28c840"></span>
                                </div>
                                <div class="mock-url" id="mock-url">webix.com.mx</div>
                            </div>
                            <div class="mock-screens">

                                <!-- Día 1: Hablamos — chat de WhatsApp -->
                                <div class="mock-screen active" id="screen-0">
                                    <div class="ms-chat">
                                        <div class="ms-bubble ms-bubble--in">
                                            <div class="ms-bubble-dot"></div>
                                            Hola, quiero una página web para mi negocio
                                        </div>
                                        <div class="ms-bubble ms-bubble--out ms-delay-1">¡Claro! Cuéntame de tu negocio y qué necesitas 🚀</div>
                                        <div class="ms-bubble ms-bubble--in ms-delay-2">
                                            <div class="ms-bubble-dot"></div>
                                            Tengo una cafetería en CDMX. Quiero que me encuentren en Google.
                                        </div>
                                        <div class="ms-bubble ms-bubble--out ms-delay-3">Perfecto. ¿Tienes logo, fotos, algo de branding?</div>
                                        <div class="ms-typing ms-delay-4">
                                            <span></span><span></span><span></span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Día 2: Proponemos — propuesta / PDF -->
                                <div class="mock-screen" id="screen-1">
                                    <div class="ms-propuesta">
                                        <div class="ms-prop-header ms-delay-0">
                                            <div class="ms-prop-icon">
                                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="#AF4D98" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M14 2v6h6" stroke="#AF4D98" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                            </div>
                                            <div class="ms-prop-title">Propuesta Webix</div>
                                        </div>
                                        <div class="ms-prop-body ms-delay-1">
                                            <div class="ms-prop-row">
                                                <span class="ms-prop-label">Proyecto</span>
                                                <span class="ms-prop-val">Sitio web 5 secciones</span>
                                            </div>
                                            <div class="ms-prop-row">
                                                <span class="ms-prop-label">Entrega</span>
                                                <span class="ms-prop-val">7 días</span>
                                            </div>
                                            <div class="ms-prop-row">
                                                <span class="ms-prop-label">Incluye</span>
                                                <span class="ms-prop-val">Diseño · Código · SEO · SSL</span>
                                            </div>
                                            <div class="ms-prop-row ms-prop-total">
                                                <span class="ms-prop-label">Inversión</span>
                                                <span class="ms-prop-val" style="color:#AF4D98;font-size:1.2rem;">$X,XXX MXN</span>
                                            </div>
                                        </div>
                                        <div class="ms-prop-cta ms-delay-2">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="#28c840" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                            Presupuesto cerrado. Sin sorpresas.
                                        </div>
                                    </div>
                                </div>

                                <!-- Día 3: Diseñamos — Figma frame -->
                                <div class="mock-screen" id="screen-2">
                                    <div class="ms-figma">
                                        <div class="ms-fig-toolbar ms-delay-0">
                                            <div class="ms-fig-logo">
                                                <span style="background:#AF4D98"></span>
                                                <span style="background:#119DA4"></span>
                                                <span style="background:#FF7B00"></span>
                                            </div>
                                            <span class="ms-fig-fname">Homepage · Draft</span>
                                        </div>
                                        <div class="ms-fig-canvas ms-delay-1">
                                            <div class="ms-fig-nav">
                                                <div class="ms-fig-logo-sm"></div>
                                                <div class="ms-fig-links"><span></span><span></span><span></span></div>
                                            </div>
                                            <div class="ms-fig-hero">
                                                <div class="ms-fig-h1"></div>
                                                <div class="ms-fig-h2"></div>
                                                <div class="ms-fig-cta">Contáctanos</div>
                                            </div>
                                            <div class="ms-fig-cards">
                                                <div class="ms-fig-card" style="--accent:#AF4D98"></div>
                                                <div class="ms-fig-card" style="--accent:#119DA4"></div>
                                                <div class="ms-fig-card" style="--accent:#FF7B00"></div>
                                            </div>
                                        </div>
                                        <div class="ms-fig-badge ms-delay-2">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.56 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z" fill="#FFE900" stroke="#FFE900" stroke-width="1"/></svg>
                                            Diseño enviado para revisión
                                        </div>
                                    </div>
                                </div>

                                <!-- Día 4: Construimos — código en editor -->
                                <div class="mock-screen" id="screen-3">
                                    <div class="ms-code">
                                        <div class="ms-code-line ms-delay-0"><span class="ms-kw">&lt;section</span> <span class="ms-attr">class</span>=<span class="ms-str">"hero"</span><span class="ms-kw">&gt;</span></div>
                                        <div class="ms-code-line ms-delay-1 ms-indent"><span class="ms-kw">&lt;h1&gt;</span><span class="ms-txt">Tu negocio en línea</span><span class="ms-kw">&lt;/h1&gt;</span></div>
                                        <div class="ms-code-line ms-delay-2 ms-indent"><span class="ms-kw">&lt;p&gt;</span><span class="ms-txt">Descripción del servicio...</span><span class="ms-kw">&lt;/p&gt;</span></div>
                                        <div class="ms-code-line ms-delay-3 ms-indent"><span class="ms-kw">&lt;a</span> <span class="ms-attr">href</span>=<span class="ms-str">"#contacto"</span><span class="ms-kw">&gt;</span><span class="ms-txt">Contáctanos</span><span class="ms-kw">&lt;/a&gt;</span></div>
                                        <div class="ms-code-line ms-delay-4"><span class="ms-kw">&lt;/section&gt;</span></div>
                                        <div class="ms-code-line ms-delay-5"><span class="ms-kw">&lt;section</span> <span class="ms-attr">class</span>=<span class="ms-str">"servicios"</span><span class="ms-kw">&gt;</span></div>
                                        <div class="ms-code-line ms-delay-6 ms-indent"><span class="ms-comment">/* 3 cards con animación */</span></div>
                                        <div class="ms-code-cursor ms-delay-7">█</div>
                                    </div>
                                </div>

                                <!-- Día 5: Ajustamos — feedback / cambios -->
                                <div class="mock-screen" id="screen-4">
                                    <div class="ms-ajustes">
                                        <div class="ms-aj-header ms-delay-0">
                                            <div class="ms-aj-avatar">Tú</div>
                                            <div class="ms-aj-msg">Me encanta cómo va. ¿Podemos cambiar la foto del hero y el texto del botón?</div>
                                        </div>
                                        <div class="ms-aj-preview ms-delay-1">
                                            <div class="ms-aj-prev-head">
                                                <div class="ms-aj-prev-logo"></div>
                                                <span class="ms-aj-prev-label">v2 · con cambios</span>
                                            </div>
                                            <div class="ms-aj-prev-img"></div>
                                        </div>
                                        <div class="ms-aj-check ms-delay-2">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="#28c840" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                            Cambios aplicados. Sin costo extra.
                                        </div>
                                    </div>
                                </div>

                                <!-- Día 6: Checklist — revisión final -->
                                <div class="mock-screen" id="screen-5">
                                    <div class="ms-checklist">
                                        <div class="ms-cl-title ms-delay-0">Pre-lanzamiento</div>
                                        <div class="ms-cl-items">
                                            <div class="ms-cl-item ms-delay-1">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="#28c840" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                                <span>Velocidad y responsive verificado</span>
                                            </div>
                                            <div class="ms-cl-item ms-delay-2">
