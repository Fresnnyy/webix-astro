    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" is:inline></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" is:inline></script>
    <script>
    gsap.registerPlugin(ScrollTrigger);
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduced) {
        const lines = gsap.utils.toArray('.hero-line');
        gsap.set(lines, { y: 40, opacity: 0 });
        gsap.to(lines, { y: 0, opacity: 1, duration: 0.9, stagger: 0.1, ease: 'power3.out', delay: 0.3 });
        gsap.from('.btn-hero', { y: 30, opacity: 0, duration: 0.8, ease: 'power3.out', delay: 0.9 });
        gsap.from('.hero-badge', { opacity: 0, scale: 0.6, duration: 0.7, stagger: 0.1, ease: 'back.out(1.6)', delay: 0.5 });
        gsap.utils.toArray('.desafio-card').forEach((card) => {
            gsap.from(card, {
                scrollTrigger: { trigger: card, start: 'top 85%', toggleActions: 'play none none none' },
                y: 60, opacity: 0, duration: 0.7, ease: 'power3.out'
            });
        });
        // Qué hacemos: entrada con perspectiva 3D escalonada
        gsap.utils.toArray('.qh-card').forEach((card, i) => {
            gsap.fromTo(card,
                { y: 80, opacity: 0, rotateX: 12, scale: 0.95 },
                {
                    scrollTrigger: { trigger: '#que-hacemos', start: 'top 72%', toggleActions: 'play none none none' },
                    y: 0, opacity: 1, rotateX: 0, scale: 1,
                    duration: 0.75, ease: 'power3.out',
                    delay: i * 0.13,
                }
            );
        });
    }
    const spotlightData = [
        { img: '/img/cliente-5.webp', name: 'Emilio Vargas',  role: 'CEO, Agencia de Seguros',    quote: '\u00a1Incre\u00edble! Pens\u00e9 que tener una p\u00e1gina profesional ser\u00eda complicad\u00edsimo, pero el equipo lo hizo s\u00faper f\u00e1cil y r\u00e1pido. \u00a1Totalmente recomendados!' },
        { img: '/img/cliente-1.webp', name: 'Carla Andrade',  role: 'Director de Operaciones',    quote: 'Saben exactamente c\u00f3mo dise\u00f1ar para convertir visitas en clientes reales. Mi equipo y yo estamos muy contentos con el proyecto final entregado.' },
        { img: '/img/cliente-2.webp', name: 'Alejandro Ruiz', role: 'Consultor Tecnol\u00f3gico', quote: 'La atenci\u00f3n al cliente es otro nivel. Respondieron a mis dudas de inmediato en todo momento y el resultado final super\u00f3 mis expectativas por completo.' },
        { img: '/img/cliente-3.webp', name: 'Sof\u00eda M\u00e1rquez', role: 'Fundadora, Moda E-commerce', quote: 'Desde el primer d\u00eda entendieron lo que mi tienda online necesitaba. El dise\u00f1o es moderno y mis ventas han subido notablemente desde que lo lanzamos.' },
        { img: '/img/cliente-4.webp', name: 'Diego Luna',     role: 'Dise\u00f1ador Freelance',   quote: 'Mi portafolio nunca luci\u00f3 mejor. Entendieron mi estilo desde el principio y lo reflejaron en una web s\u00faper din\u00e1mica y elegante. \u00a1Gracias, chicos!' },
        { img: '/img/cliente-6.webp', name: 'Andrea Torres',  role: 'Gerente de Marketing',       quote: 'El soporte t\u00e9cnico ha sido impecable. Cualquier ajuste que necesito lo resuelven r\u00e1pido y siempre con la mejor actitud. Son unos profesionales de pies a cabeza.' }
    ];
    const spotCard = document.getElementById('spotlight-card');
    const spotDots = document.getElementById('spotlight-dots');
    let spotCurrent = 0, spotAuto = null, spotAnimating = false;
    spotlightData.forEach((_, i) => {
        const d = document.createElement('button');
        d.className = 'spotlight-dot' + (i === 0 ? ' active' : '');
        d.setAttribute('aria-label', 'Testimonio ' + (i + 1));
        d.addEventListener('click', () => spotGoTo(i));
        spotDots.appendChild(d);
    });
    function spotRender(index) {
        const t = spotlightData[index];
        spotCard.innerHTML = '<div class="spotlight-photo-blob"><div class="spotlight-blob-bg"></div><img src="' + t.img + '" alt="Foto de ' + t.name + '" loading="lazy"></div><div class="spotlight-text"><span class="spotlight-deco-quote">\u201c</span><p class="spotlight-quote">\u201c' + t.quote + '\u201d</p><p class="spotlight-name">' + t.name + '</p><p class="spotlight-role">' + t.role + '</p></div>';
    }
    function spotUpdateDots() { spotDots.querySelectorAll('.spotlight-dot').forEach((d, i) => d.classList.toggle('active', i === spotCurrent)); }
    function spotGoTo(index, direction) {
        if (spotAnimating || index === spotCurrent) return;
        spotAnimating = true;
        if (direction === undefined) direction = index > spotCurrent ? 1 : -1;
        gsap.to(spotCard, { opacity: 0, x: direction * -60, duration: 0.35, ease: 'power2.in', onComplete: function() {
            spotCurrent = index; spotRender(spotCurrent); spotUpdateDots();
            gsap.fromTo(spotCard, { opacity: 0, x: direction * 60 }, { opacity: 1, x: 0, duration: 0.45, ease: 'power2.out', onComplete: function() { spotAnimating = false; } });
        }});
        spotResetAuto();
    }
    function spotNext() { spotGoTo((spotCurrent + 1) % spotlightData.length, 1); }
    function spotPrev() { spotGoTo((spotCurrent - 1 + spotlightData.length) % spotlightData.length, -1); }
    document.getElementById('spotlight-prev').addEventListener('click', spotPrev);
    document.getElementById('spotlight-next').addEventListener('click', spotNext);
    document.getElementById('spotlight-prev-mob').addEventListener('click', spotPrev);
    document.getElementById('spotlight-next-mob').addEventListener('click', spotNext);
    function spotStartAuto() { spotAuto = setInterval(spotNext, 5000); }
    function spotStopAuto()  { clearInterval(spotAuto); }
    function spotResetAuto() { spotStopAuto(); spotStartAuto(); }
    spotCard.addEventListener('mouseenter', spotStopAuto);
    spotCard.addEventListener('mouseleave', spotStartAuto);
    let spotTouchX = 0;
    spotCard.addEventListener('touchstart', function(e) { spotTouchX = e.changedTouches[0].clientX; }, { passive: true });
    spotCard.addEventListener('touchend', function(e) { var diff = e.changedTouches[0].clientX - spotTouchX; if (Math.abs(diff) > 50) diff > 0 ? spotPrev() : spotNext(); }, { passive: true });
    spotRender(0);
    spotStartAuto();
    </script>
    <script>
    // ── PROCESO ──────────────────────────────────────────────
    const pasos   = document.querySelectorAll('.paso-item');
    const screens = document.querySelectorAll('.mock-screen');
    const mockUrl = document.getElementById('mock-url');
    const urls = [
        'diagnostico · webix.com.mx',
        'propuesta · webix.com.mx',
        'diseño · webix.com.mx',
        'dev · webix.com.mx',
        'ajustes · webix.com.mx',
        'checklist · webix.com.mx',
        'webix.com.mx ✓',
    ];
    function activatePaso(index) {
        pasos.forEach((p, i)   => p.classList.toggle('is-active', i === index));
        screens.forEach((s, i) => s.classList.toggle('active', i === index));
        if (mockUrl) mockUrl.textContent = urls[index];
    }
    pasos.forEach((paso, i) => {
        ScrollTrigger.create({
            trigger: paso,
            start: 'top 55%',
            end: 'bottom 55%',
            onEnter:      () => activatePaso(i),
            onEnterBack:  () => activatePaso(i),
        });
    });
    activatePaso(0);

    // ── PORTAFOLIO ───────────────────────────────────────────
    const isMobile = () => window.innerWidth < 768;
    const fanCards = Array.from(document.querySelectorAll('.fan-card'));
    const fanMobile = document.querySelector('.fan-mobile');
    const fanBase = [
        { x: -340, y: 40,  rot: -22, z: 1 },
        { x: -115, y: 10,  rot:  -7, z: 2 },
        { x:  115, y: 10,  rot:   7, z: 3 },
        { x:  340, y: 40,  rot:  22, z: 4 },
    ];
    function initFan() {
        if (isMobile()) {
            fanCards.forEach(c => (c.style.display = 'none'));
            if (fanMobile) fanMobile.classList.remove('hidden');
            return;
        }
        if (fanMobile) fanMobile.classList.add('hidden');
        fanCards.forEach((card, i) => {
            card.style.display = '';
            gsap.set(card, { x: fanBase[i].x, y: fanBase[i].y, rotation: fanBase[i].rot, zIndex: fanBase[i].z, scale: 1 });
        });
    }
    initFan();
    window.addEventListener('resize', initFan);
    fanCards.forEach((card, i) => {
        card.addEventListener('mouseenter', () => {
            if (isMobile()) return;
            gsap.to(card, { y: fanBase[i].y - 70, rotation: 0, scale: 1.05, zIndex: 10, duration: 0.45, ease: 'power3.out' });
            fanCards.forEach((other, j) => {
                if (j === i) return;
                gsap.to(other, { x: fanBase[j].x + (j < i ? -25 : 25), duration: 0.45, ease: 'power3.out' });
            });
        });
        card.addEventListener('mouseleave', () => {
            if (isMobile()) return;
            gsap.to(card, { y: fanBase[i].y, rotation: fanBase[i].rot, scale: 1, zIndex: fanBase[i].z, duration: 0.6, ease: 'elastic.out(1, 0.75)' });
            fanCards.forEach((other, j) => {
                if (j === i) return;
                gsap.to(other, { x: fanBase[j].x, duration: 0.6, ease: 'elastic.out(1, 0.75)' });
            });
        });
    });
    </script>

    <style is:global>
